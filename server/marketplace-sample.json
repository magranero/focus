      "category": "inspiration",
      "pkg": {
        "manifest": {
          "name": "Daily Stoic Quote",
          "emoji": "🏛️",
          "version": "1.0.0",
          "author": "FOCUS team",
          "defaultSize": { "w": 4, "h": 2 },
          "settings": [],
          "allowedDomains": [],
          "sampleData": null
        },
        "html": "<!doctype html><html><head><meta charset=\"utf-8\"><script src=\"/bridge.js\"></script><style>html,body{margin:0;height:100%;font-family:Georgia,serif;color:#e2e8f0;background:transparent}.wrap{display:flex;flex-direction:column;justify-content:center;height:100%;padding:16px;box-sizing:border-box}.q{font-size:15px;font-style:italic;line-height:1.5}.a{margin-top:8px;font-size:12px;opacity:.7;text-align:right}</style></head><body><div class=\"wrap\"><div class=\"q\" id=\"q\"></div><div class=\"a\" id=\"a\"></div></div><script>const quotes=[[\"You have power over your mind — not outside events.\",\"Marcus Aurelius\"],[\"We suffer more often in imagination than in reality.\",\"Seneca\"],[\"No man is free who is not master of himself.\",\"Epictetus\"],[\"He who fears death will never do anything worthy of a living man.\",\"Seneca\"],[\"The obstacle is the way.\",\"Marcus Aurelius\"]];const d=new Date();const i=(d.getFullYear()*366+d.getMonth()*31+d.getDate())%quotes.length;document.getElementById('q').textContent='“'+quotes[i][0]+'”';document.getElementById('a').textContent='— '+quotes[i][1];</script></body></html>"
      }
